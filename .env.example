# Neon connection string (from Neon dashboard > Connection Details > Connection string)
# Use the "pooled" URL for production (includes ?pgbouncer=true)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Port for the HTTP server (SSE + health)
PORT=3000

# Workato API token for future recipe/API calls
WORKATO_API_TOKEN=your-workato-api-token

# Community Voices API token for future community integrations
COMM_VOICES_API_TOKEN=your-community-voices-api-token

# Workato webhook fired when a participant registers
# Workato > Recipes > Your recipe > HTTP trigger URL
WORKATO_REGISTER_WEBHOOK=https://apim.workato.com/your-org/webhook/register

# Workato webhook fired when a team is confirmed
WORKATO_TEAM_WEBHOOK=https://apim.workato.com/your-org/webhook/teams

# Workato webhook fired when awards are triggered
WORKATO_AWARDS_WEBHOOK=https://apim.workato.com/your-org/webhook/awards

# Optional: shared secret Workato sends in X-Workato-Token header for inbound hooks
WORKATO_WEBHOOK_SECRET=your-webhook-secret
